---
/**
 * Bloque de resultado en forma de INFORME interactivo (estilo valuations.com):
 * cabecera con sector + valoración enorme, sliders (facturación/margen/crecimiento)
 * que recalculan en vivo, curva de probabilidad y desglose por métodos.
 * Oculto hasta que el usuario calcula. El número sigue siendo gratis y sin pedir nada.
 */
import textos from "../config/textos.json";
import Disclaimer from "./Disclaimer.astro";
import Ganchos from "./Ganchos.astro";
import FormLead from "./FormLead.astro";
---

<section class="resultado" id="resultado" hidden aria-live="polite">
  <div class="informe-card">
    <!-- Cabecera: sector + valoración enorme -->
    <div class="informe-header">
      <div class="informe-empresa-wrap">
        <p class="informe-sector" id="informe-sector">—</p>
        <p class="informe-empresa">{textos.resultado.titulo}</p>
      </div>
      <div class="informe-valor-wrap">
        <p class="informe-valor-label">Valor estimado</p>
        <p class="informe-valor" id="resultado-central">—</p>
        <p class="informe-rango">Rango: <span id="resultado-rango">—</span></p>
      </div>
    </div>

    <!-- Sliders: mueve las hipótesis y mira cómo cambia el valor en vivo -->
    <p class="informe-sliders-ayuda">
      Ajusta las palancas para afinar tu caso. La valoración se recalcula al instante.
    </p>
    <div class="informe-sliders" id="informe-sliders"></div>

    <!-- Curva de probabilidad de precio -->
    <div class="curva hidden" id="curva-precio">
      <div class="curva-cabecera">
        <h3>Tu horquilla de precio de venta</h3>
        <p class="curva-hook" id="curva-hook"></p>
      </div>
      <div
        class="curva-svg"
        id="curva-svg"
        role="img"
        aria-label="Curva de probabilidad del precio de venta y franjas por tipo de comprador"
      >
      </div>
      <div class="curva-leyenda">
        <span class="curva-lg curva-lg-band">Rango probable</span>
        <span class="curva-lg curva-lg-fin">Comprador financiero</span>
        <span class="curva-lg curva-lg-est">Comprador estratégico</span>
      </div>
      <p class="curva-nota">
        Orientativo. El comprador <strong>financiero</strong> (fondos, inversores) mira rentabilidad y
        suele pagar en la parte baja-media; el <strong>estratégico</strong> (un competidor o grupo del
        sector) paga por sinergias y tiende a la parte alta.
      </p>
    </div>

    <!-- Métodos de valoración (donut de pesos + tabla) -->
    <div class="metodos" id="metodos">
      <h3>Cómo se compone tu valoración</h3>
      <p class="metodos-ayuda">
        Combinamos tres métodos estándar. Cada uno pesa distinto según su fiabilidad para una pyme.
      </p>
      <div class="metodos-grid">
        <div class="metodos-donut" id="metodos-donut" role="img" aria-label="Peso de cada método de valoración"></div>
        <table class="metodos-tabla">
          <thead>
            <tr><th>Método</th><th>Valoración</th><th>Peso</th></tr>
          </thead>
          <tbody id="metodos-tbody"></tbody>
          <tfoot>
            <tr><th>Valoración combinada</th><td id="metodos-total">—</td><td>100 %</td></tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>

  <Disclaimer />

  <button type="button" class="btn btn-primary btn-lg" id="btn-pedir-informe">
    {textos.resultado.cta_informe}
  </button>
  <p style="font-size: 0.85rem; color: var(--color-gray-500); margin-top: 0.5rem;">
    {textos.resultado.cta_informe_subtexto}
  </p>

  <FormLead />

  <h2 style="margin-top: 3rem;">¿Y ahora qué?</h2>
  <p style="color: var(--color-gray-500);">Dinos qué te ronda la cabeza y te ayudamos con el siguiente paso.</p>
  <Ganchos />
</section>
