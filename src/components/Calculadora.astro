---
/**
 * Calculadora de valoración con 3 niveles.
 * Toda la lógica de cálculo vive en src/lib/ y los parámetros en src/config/.
 * El script de abajo se encarga de: tabs, cálculo, resultado, envío silencioso
 * a Netlify (form "calculos"), ganchos de perfil y captura de lead.
 */
---

<!-- Form estático oculto para que Netlify detecte "calculos" en build -->
<form name="calculos" data-netlify="true" hidden aria-hidden="true">
  <input type="text" name="nivel" />
  <input type="text" name="sector" />
  <input type="text" name="ventas" />
  <input type="text" name="ebitda" />
  <input type="text" name="antiguedad" />
  <input type="text" name="rango_min" />
  <input type="text" name="rango_max" />
</form>

<section class="section" id="calculadora">
  <div class="container">
    <div class="calculadora">
      <h2 class="text-center">Calcula el valor de tu empresa</h2>
      <p class="text-center" style="color: var(--color-gray-500); margin-bottom: 1.5rem;">
        Elige cuánta información quieres darnos. Más datos = valoración más ajustada.
      </p>

      <!-- Selector de nivel -->
      <div class="nivel-tabs" role="tablist" aria-label="Nivel de detalle">
        <button type="button" class="nivel-tab" role="tab" aria-selected="true" data-nivel="1" id="tab-1">
          <strong>Rápido</strong>
          <span>Solo facturación · 30 seg</span>
        </button>
        <button type="button" class="nivel-tab" role="tab" aria-selected="false" data-nivel="2" id="tab-2">
          <strong>Medio</strong>
          <span>Con tu EBITDA real</span>
        </button>
        <button type="button" class="nivel-tab" role="tab" aria-selected="false" data-nivel="3" id="tab-3">
          <strong>Avanzado</strong>
          <span>Simula tu crecimiento</span>
        </button>
      </div>

      <form id="form-calculadora" novalidate>
        <!-- Facturación: común a todos los niveles -->
        <div class="campo">
          <label for="in-ventas">Facturación anual (€)</label>
          <input type="number" id="in-ventas" inputmode="numeric" min="0" step="1000" placeholder="Ej.: 1.500.000" required />
          <p class="ayuda">Las ventas totales de tu último año completo.</p>
        </div>

        <!-- Sector: común a todos los niveles -->
        <div class="campo">
          <label for="in-sector">Sector</label>
          <select id="in-sector" required>
            <option value="" disabled selected>Elige tu sector</option>
          </select>
        </div>

        <!-- EBITDA: niveles 2 y 3 -->
        <div class="campo campo-nivel-2 campo-nivel-3 hidden">
          <label for="in-ebitda">EBITDA anual (€)</label>
          <input type="number" id="in-ebitda" inputmode="numeric" step="1000" placeholder="Ej.: 250.000" />
          <p class="ayuda">Beneficio antes de intereses, impuestos y amortizaciones. Si no lo sabes, usa el nivel Rápido.</p>
        </div>

        <!-- Antigüedad: nivel 2 -->
        <div class="campo campo-nivel-2 hidden">
          <label for="in-antiguedad">Años de antigüedad de la empresa</label>
          <input type="number" id="in-antiguedad" inputmode="numeric" min="0" max="200" placeholder="Ej.: 15" />
          <p class="ayuda">Una empresa consolidada suele valorarse en la parte alta del rango.</p>
        </div>

        <!-- Proyecciones: nivel 3 -->
        <div class="campo campo-nivel-3 hidden">
          <label for="in-crecimiento">¿Cuánto crees que crecerás al año? (%)</label>
          <input type="number" id="in-crecimiento" inputmode="decimal" step="0.5" value="5" />
          <p class="ayuda">Una estimación de crecimiento anual. Luego, en el resultado, podrás moverla y ver cómo cambia el valor.</p>
        </div>

        <button type="submit" class="btn btn-primary btn-lg btn-calcular" id="btn-calcular">
          Calcular valoración
        </button>
        <p class="form-msg error" id="calc-error" role="alert"></p>

        <!-- Mata la objeción nº 1 (desconfianza) justo donde surge -->
        <p class="nota-confianza">
          🔒 Tus datos no salen de tu navegador. No pedimos teléfono ni email para darte el resultado.
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  import sectoresConfig from "../config/sectores.json";
  import waccConfig from "../config/wacc.json";
  import antiguedadConfig from "../config/antiguedad.json";
  import textosConfig from "../config/textos.json";
  import { calcularInforme } from "../lib/informe.js";
  import { modeloCurva } from "../lib/curva-precio.js";
  import features from "../config/features.json";

  // ── Estado ────────────────────────────────────────────────────────────────
  let nivelActivo = 1;
  let ultimoResultado = null; // guarda el último cálculo para el PDF
  let ultimosInputs = null;

  // ── Utilidades ────────────────────────────────────────────────────────────
  const $ = (sel) => document.querySelector(sel);

  const fmtEUR = (n) =>
    new Intl.NumberFormat("es-ES", {
      style: "currency",
      currency: "EUR",
      maximumFractionDigits: 0,
    }).format(n);

  /** Envío de formularios a Netlify Forms por fetch (x-www-form-urlencoded). */
  function postNetlify(formName, data) {
    const body = new URLSearchParams({ "form-name": formName, ...data }).toString();
    return fetch("/", {
      method: "POST",
      headers: { "Content-Type": "application/x-www-form-urlencoded" },
      body,
    });
  }

  /** Evento de analítica (Plausible o compatible). No hace nada si no está cargada. */
  function track(evento, props) {
    if (typeof window.plausible === "function") {
      window.plausible(evento, props ? { props } : undefined);
    }
  }

  // ── Poblar el selector de sectores desde el JSON ──────────────────────────
  const selectSector = $("#in-sector");
  sectoresConfig.sectores.forEach((s) => {
    const opt = document.createElement("option");
    opt.value = s.id;
    opt.textContent = s.nombre;
    selectSector.appendChild(opt);
  });

  // Preselección por URL (?sector=xxx): las páginas de sector enlazan así
  const sectorURL = new URLSearchParams(window.location.search).get("sector");
  if (sectorURL && sectoresConfig.sectores.some((s) => s.id === sectorURL)) {
    selectSector.value = sectorURL;
  }

  // ── Tabs de nivel ─────────────────────────────────────────────────────────
  document.querySelectorAll(".nivel-tab").forEach((tab) => {
    tab.addEventListener("click", () => {
      nivelActivo = parseInt(tab.dataset.nivel, 10);
      document.querySelectorAll(".nivel-tab").forEach((t) => {
        t.setAttribute("aria-selected", t === tab ? "true" : "false");
      });
      // Muestra/oculta campos según nivel
      document.querySelectorAll("[class*='campo-nivel-']").forEach((el) => {
        el.classList.add("hidden");
      });
      document.querySelectorAll(`.campo-nivel-${nivelActivo}`).forEach((el) => {
        el.classList.remove("hidden");
      });
      $("#calc-error").textContent = "";
    });
  });

  // Enlaces de otras secciones que abren directamente un nivel (p.ej. "3 factores")
  document.querySelectorAll("[data-abrir-nivel]").forEach((el) => {
    el.addEventListener("click", () => {
      const tab = document.getElementById(`tab-${el.dataset.abrirNivel}`);
      if (tab) tab.click();
    });
  });

  // ── Cálculo ───────────────────────────────────────────────────────────────
  $("#form-calculadora").addEventListener("submit", (e) => {
    e.preventDefault();
    const errorEl = $("#calc-error");
    errorEl.textContent = "";

    const ventas = parseFloat($("#in-ventas").value);
    const sectorId = selectSector.value;

    if (!ventas || ventas <= 0) {
      errorEl.textContent = "Introduce tu facturación anual.";
      $("#in-ventas").focus();
      return;
    }
    if (!sectorId) {
      errorEl.textContent = "Elige tu sector.";
      selectSector.focus();
      return;
    }

    // Según el nivel, derivamos las 3 palancas del informe: margen y crecimiento.
    const sector = sectoresConfig.sectores.find((s) => s.id === sectorId);
    let margen; // tanto por uno
    let crecimiento = 0.05; // por defecto 5 %/año si el usuario no lo especifica

    if (nivelActivo === 1) {
      margen = sector.margen_ebitda_default;
    } else {
      const ebitda = parseFloat($("#in-ebitda").value);
      if (!ebitda || ebitda <= 0) {
        errorEl.textContent =
          nivelActivo === 2
            ? "Introduce tu EBITDA (o usa el nivel Rápido si no lo conoces)."
            : "Introduce tu EBITDA para poder proyectar los flujos.";
        $("#in-ebitda").focus();
        return;
      }
      margen = ebitda / ventas;
      if (nivelActivo === 3) {
        crecimiento = (parseFloat($("#in-crecimiento").value) || 0) / 100;
      }
    }

    let resultado;
    try {
      resultado = calcularInforme({ ventas, margen, crecimiento, sectorId }, sectoresConfig, waccConfig);
    } catch (err) {
      errorEl.textContent = "Ha ocurrido un error en el cálculo. Revisa los datos.";
      console.error(err);
      return;
    }

    ultimoResultado = resultado;
    ultimosInputs = { ventas, sectorId, nivel: nivelActivo, margen, crecimiento };
    mostrarResultado(resultado);
    enviarCalculoSilencioso(ultimosInputs, resultado);
    track("Calculo", { nivel: String(nivelActivo), sector: sectorId });
  });

  // ── Mostrar resultado: informe interactivo (gratis, enorme, sin pedir nada) ─
  function mostrarResultado(r) {
    montarSliders();
    actualizarInforme(r);

    const resultadoEl = $("#resultado");
    resultadoEl.hidden = false;
    resultadoEl.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  /** Refresca cabecera, curva, métodos y el hidden del lead con el resultado dado. */
  function actualizarInforme(r) {
    $("#informe-sector").textContent = r.sectorNombre;
    $("#resultado-central").textContent = fmtEUR(r.valorCentral);
    $("#resultado-rango").textContent = `${fmtEUR(r.valorMin)} — ${fmtEUR(r.valorMax)}`;
    $("#lead-resultado").value = `${r.valorMin} - ${r.valorMax} EUR (informe)`;
    if (features.curvaProbabilidad) pintarCurva(r);
    pintarMetodos(r);
    pintarBenchmark(r);
  }

  // Benchmark: margen EBITDA del usuario (línea roja) vs margen típico de cada
  // sector (barras, la del sector propio resaltada). Se actualiza con el slider.
  function pintarBenchmark(r) {
    const W = 840, H = 320, padL = 42, padR = 12, padT = 20, padB = 92;
    const plotW = W - padL - padR, plotH = H - padT - padB;
    const bottom = padT + plotH;
    const sec = sectoresConfig.sectores;
    const userM = r.margen;
    const maxVal = Math.max(...sec.map((s) => s.margen_ebitda_default), userM);
    const yMax = Math.max(0.05, Math.ceil((maxVal * 1.15) / 0.05) * 0.05);
    const yTo = (v) => bottom - (v / yMax) * plotH;
    const bandW = plotW / sec.length;
    const barW = Math.min(48, bandW * 0.6);

    let grid = "";
    for (let g = 0; g <= yMax + 1e-9; g += 0.05) {
      const y = yTo(g);
      grid +=
        `<line x1="${padL}" y1="${y.toFixed(1)}" x2="${W - padR}" y2="${y.toFixed(1)}" stroke="#e2e8f0"/>` +
        `<text x="${padL - 6}" y="${(y + 4).toFixed(1)}" text-anchor="end" class="bm-tick">${Math.round(g * 100)}%</text>`;
    }

    let bars = "";
    sec.forEach((s, i) => {
      const cx = padL + bandW * i + bandW / 2;
      const bx = cx - barW / 2;
      const by = yTo(s.margen_ebitda_default);
      const activo = s.id === r.sectorId;
      const lbl = s.nombre.split(" / ")[0];
      bars +=
        `<rect x="${bx.toFixed(1)}" y="${by.toFixed(1)}" width="${barW.toFixed(1)}" height="${(bottom - by).toFixed(1)}" rx="3" fill="${activo ? "#2563eb" : "#94a3b8"}"><title>${s.nombre}: ${Math.round(s.margen_ebitda_default * 100)}%</title></rect>` +
        `<text x="${cx.toFixed(1)}" y="${(bottom + 14).toFixed(1)}" text-anchor="end" transform="rotate(-35 ${cx.toFixed(1)} ${(bottom + 14).toFixed(1)})" class="bm-lbl${activo ? " bm-lbl-on" : ""}">${lbl}</text>`;
    });

    const yU = yTo(userM);
    const linea =
      `<line x1="${padL}" y1="${yU.toFixed(1)}" x2="${W - padR}" y2="${yU.toFixed(1)}" stroke="#dc2626" stroke-width="2"/>` +
      `<rect x="${padL + 4}" y="${(yU - 17).toFixed(1)}" width="140" height="16" rx="3" fill="#dc2626"/>` +
      `<text x="${padL + 11}" y="${(yU - 5).toFixed(1)}" class="bm-you">Tu margen: ${Math.round(userM * 100)}%</text>`;

    $("#benchmark-svg").innerHTML =
      `<svg viewBox="0 0 ${W} ${H}" width="100%" xmlns="http://www.w3.org/2000/svg">${grid}${bars}` +
      `<line x1="${padL}" y1="${bottom}" x2="${W - padR}" y2="${bottom}" stroke="#cbd5e1"/>${linea}</svg>`;
  }

  // ── Dashboard interactivo del Nivel 3 ────────────────────────────────────
  // El usuario mueve el crecimiento y todo se recalcula en vivo.
  // El WACC se muestra pero NO es editable (lo fija sector + tamaño).
  const fmtCorto = (n) =>
    n >= 950000
      ? (n / 1e6).toLocaleString("es-ES", { maximumFractionDigits: 1 }) + " M€"
      : Math.round(n / 1000).toLocaleString("es-ES") + " k€";

  const fmtPct = (n) => n.toLocaleString("es-ES", { maximumFractionDigits: 1 }) + " %";

  // ── Curva de probabilidad de precio (los 3 niveles) ──────────────────────
  // Dibuja una campana sobre el rango [mín, máx] + franjas por tipo de comprador.
  function pintarCurva(r) {
    const wrap = $("#curva-precio");
    const m = modeloCurva(r);

    // Titular tipo "hay un X % de probabilidad de vender por Y o más"
    $("#curva-hook").innerHTML =
      `Hay un <strong>${Math.round(m.pFloor * 100)} %</strong> de probabilidad de vender por ` +
      `<strong>${fmtCorto(m.valorMin)}</strong> o más.`;

    // Lienzo (viewBox responsive; el CSS lo escala al ancho disponible)
    const W = 820, H = 340;
    const padL = 20, padR = 20;
    const top = 44, bottom = 214; // zona de la campana
    const plotW = W - padL - padR;
    const x = (v) => padL + ((v - m.xIni) / (m.xFin - m.xIni)) * plotW;
    const yBell = (yn) => bottom - yn * (bottom - top);

    // Trazado de la campana
    const p0 = m.puntos[0];
    const pN = m.puntos[m.puntos.length - 1];
    const segs = m.puntos.map((p) => `L ${x(p.x).toFixed(1)} ${yBell(p.y).toFixed(1)}`);
    const linea = `M ${x(p0.x).toFixed(1)} ${yBell(p0.y).toFixed(1)} ${segs.slice(1).join(" ")}`;
    const area = `M ${x(p0.x).toFixed(1)} ${bottom} ${segs.join(" ")} L ${x(pN.x).toFixed(1)} ${bottom} Z`;

    // Etiquetas del eje X (5 marcas)
    let ticks = "";
    for (let i = 0; i <= 4; i++) {
      const v = m.xIni + ((m.xFin - m.xIni) * i) / 4;
      const px = x(v);
      ticks +=
        `<line x1="${px.toFixed(1)}" y1="${bottom}" x2="${px.toFixed(1)}" y2="${bottom + 5}" stroke="#cbd5e1"/>` +
        `<text x="${px.toFixed(1)}" y="${bottom + 20}" text-anchor="middle" class="cx-tick">${fmtCorto(v)}</text>`;
    }

    // Franja del rango probable [mín, máx]
    const bandX1 = x(m.valorMin), bandX2 = x(m.valorMax);
    const band = `<rect x="${bandX1.toFixed(1)}" y="${top}" width="${(bandX2 - bandX1).toFixed(1)}" height="${bottom - top}" fill="#dbeafe" opacity="0.55"/>`;

    // Marcador de la estimación central
    const mx = x(m.valorCentral);
    const marcador =
      `<line x1="${mx.toFixed(1)}" y1="${top - 6}" x2="${mx.toFixed(1)}" y2="${bottom}" stroke="#1a2b4a" stroke-width="2" stroke-dasharray="4 4"/>` +
      `<circle cx="${mx.toFixed(1)}" cy="${top - 6}" r="3.5" fill="#1a2b4a"/>` +
      `<text x="${mx.toFixed(1)}" y="${top - 14}" text-anchor="middle" class="cx-central">${fmtCorto(m.valorCentral)}</text>`;

    // Barras por tipo de comprador (misma escala X)
    const filas = [
      { ...m.compradores[0], color: "#059669", y: 258 },
      { ...m.compradores[1], color: "#d97706", y: 296 },
    ];
    let barras = "";
    filas.forEach((f) => {
      const bx = x(f.min), bw = Math.max(2, x(f.max) - x(f.min));
      barras +=
        `<text x="${bx.toFixed(1)}" y="${(f.y - 8).toFixed(1)}" class="cx-buyer">${f.etiqueta}</text>` +
        `<rect x="${bx.toFixed(1)}" y="${f.y}" width="${bw.toFixed(1)}" height="14" rx="7" fill="${f.color}" opacity="0.85"/>` +
        `<text x="${(x(f.max) + 8).toFixed(1)}" y="${(f.y + 11).toFixed(1)}" class="cx-range">${fmtCorto(f.min)} – ${fmtCorto(f.max)}</text>`;
    });

    $("#curva-svg").innerHTML = `
      <svg viewBox="0 0 ${W} ${H}" width="100%" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="cxFill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#2563eb" stop-opacity="0.45"/>
            <stop offset="1" stop-color="#2563eb" stop-opacity="0.02"/>
          </linearGradient>
        </defs>
        ${band}
        <path d="${area}" fill="url(#cxFill)"/>
        <path d="${linea}" fill="none" stroke="#2563eb" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>
        <line x1="${padL}" y1="${bottom}" x2="${W - padR}" y2="${bottom}" stroke="#cbd5e1"/>
        ${ticks}
        ${marcador}
        ${barras}
      </svg>`;

    wrap.classList.remove("hidden");
  }

  // Sliders del informe: facturación, margen y crecimiento. Recalculan en vivo.
  function montarSliders() {
    const { ventas, margen, crecimiento } = ultimosInputs;
    const vMin = Math.max(10000, Math.round(ventas * 0.3));
    const vMax = Math.round(ventas * 2);
    const vStep = Math.max(1000, Math.round(ventas / 100));

    $("#informe-sliders").innerHTML = `
      <div class="slider-fila">
        <label for="sl-ventas">Facturación anual</label>
        <input type="range" id="sl-ventas" min="${vMin}" max="${vMax}" step="${vStep}" value="${ventas}" />
        <span class="slider-valor" id="sl-ventas-val">${fmtEUR(ventas)}</span>
      </div>
      <div class="slider-fila">
        <label for="sl-margen">Margen EBITDA</label>
        <input type="range" id="sl-margen" min="2" max="45" step="1" value="${Math.round(margen * 100)}" />
        <span class="slider-valor" id="sl-margen-val">${Math.round(margen * 100)} %</span>
      </div>
      <div class="slider-fila">
        <label for="sl-crec">Crecimiento anual</label>
        <input type="range" id="sl-crec" min="-10" max="30" step="1" value="${Math.round(crecimiento * 100)}" />
        <span class="slider-valor" id="sl-crec-val">${Math.round(crecimiento * 100)} %</span>
      </div>`;

    $("#informe-sliders")
      .querySelectorAll("input")
      .forEach((inp) => inp.addEventListener("input", recalcularInforme));
  }

  function recalcularInforme() {
    const ventas = parseFloat($("#sl-ventas").value);
    const margen = parseFloat($("#sl-margen").value) / 100;
    const crecimiento = parseFloat($("#sl-crec").value) / 100;

    $("#sl-ventas-val").textContent = fmtEUR(ventas);
    $("#sl-margen-val").textContent = `${Math.round(margen * 100)} %`;
    $("#sl-crec-val").textContent = `${Math.round(crecimiento * 100)} %`;

    const { sectorId } = ultimosInputs;
    const r = calcularInforme({ ventas, margen, crecimiento, sectorId }, sectoresConfig, waccConfig);
    ultimoResultado = r;
    ultimosInputs = { ...ultimosInputs, ventas, margen, crecimiento };
    actualizarInforme(r);
  }

  // Desglose de métodos: donut de pesos + tabla (método / valoración / peso).
  function pintarMetodos(r) {
    const colores = { dcf: "#1a2b4a", ebitda: "#2563eb", ventas: "#93c5fd" };
    const R = 60, cx = 80, cy = 80, sw = 26;
    const C = 2 * Math.PI * R;
    let offset = 0;
    let arcs = "";
    r.metodos.forEach((m) => {
      const len = m.peso * C;
      arcs +=
        `<circle cx="${cx}" cy="${cy}" r="${R}" fill="none" stroke="${colores[m.id]}" stroke-width="${sw}" ` +
        `stroke-dasharray="${len.toFixed(2)} ${(C - len).toFixed(2)}" stroke-dashoffset="${(-offset).toFixed(2)}" ` +
        `transform="rotate(-90 ${cx} ${cy})" />`;
      offset += len;
    });
    $("#metodos-donut").innerHTML =
      `<svg viewBox="0 0 160 160" width="100%" style="max-width:180px" xmlns="http://www.w3.org/2000/svg">${arcs}` +
      `<text x="${cx}" y="${cy + 5}" text-anchor="middle" class="donut-centro">3 métodos</text></svg>`;

    $("#metodos-tbody").innerHTML = r.metodos
      .map(
        (m) =>
          `<tr><td><span class="metodo-dot" style="background:${colores[m.id]}"></span>${m.nombre}</td>` +
          `<td>${fmtEUR(m.valor)}</td><td>${Math.round(m.peso * 100)} %</td></tr>`
      )
      .join("");
    $("#metodos-total").textContent = fmtEUR(r.valorCentral);
  }

  // ── Envío silencioso del cálculo (solo el primero por sesión) ─────────────
  function enviarCalculoSilencioso(inputs, r) {
    if (sessionStorage.getItem("calculo_enviado")) return;
    sessionStorage.setItem("calculo_enviado", "1");

    postNetlify("calculos", {
      nivel: String(inputs.nivel),
      sector: inputs.sectorId,
      ventas: String(inputs.ventas),
      ebitda: String(r.ebitda ?? ""),
      antiguedad: "",
      rango_min: String(r.valorMin),
      rango_max: String(r.valorMax),
    }).catch(() => {
      /* Silencioso: si falla (p.ej. en local), no molestamos al usuario */
    });
  }

  // ── Oferta de informe PDF ─────────────────────────────────────────────────
  const ofertaEl = $("#oferta-informe");

  $("#btn-pedir-informe").addEventListener("click", () => {
    prepararFormLead("informe", "Recibe el informe detallado en PDF", "Con el desglose completo del cálculo y cómo defender tu valoración ante un comprador.");
  });

  // ── Ganchos por perfil ────────────────────────────────────────────────────
  const titulosGancho = {
    vender: ["Te enviamos la guía del proceso de venta", "Déjanos tu email y te la mandamos. Sin compromiso."],
    crecer: ["Te avisamos con ideas para subir tu valoración", "Déjanos tu email. También puedes probar ya el nivel Avanzado."],
    socios: ["Te explicamos cómo valorar una participación", "Déjanos tu email y te lo explicamos con calma."],
    tramite: ["Cuéntanos tu caso", "Explícanos para qué necesitas la valoración y te orientamos."],
    newsletter: ["Te avisamos de novedades en tu sector", "Análisis de múltiplos y mercado, sin spam."],
  };

  document.querySelectorAll(".btn-gancho").forEach((btn) => {
    btn.addEventListener("click", () => {
      const perfil = btn.dataset.perfil;

      // Registra el clic del gancho en Netlify Forms ("ganchos") + Plausible,
      // para que Marcel vea en Netlify qué CTA toca la gente.
      postNetlify("ganchos", { perfil, pagina: location.pathname }).catch(() => {});
      track("ClicGancho", { perfil });

      // El gancho "crecer" lleva además al nivel 3 (modo simulador)
      if (perfil === "crecer") {
        document.getElementById("tab-3").click();
        document.getElementById("calculadora").scrollIntoView({ behavior: "smooth" });
      }

      const [titulo, subtexto] = titulosGancho[perfil] || ["Déjanos tu email", ""];
      prepararFormLead(perfil, titulo, subtexto);
    });
  });

  function prepararFormLead(perfil, titulo, subtexto) {
    $("#lead-perfil").value = perfil;
    $("#form-lead-titulo").textContent = titulo;
    $("#form-lead-subtexto").textContent = subtexto;
    // El campo libre solo aparece para el perfil "tramite"
    $("#lead-mensaje").classList.toggle("hidden", perfil !== "tramite");
    ofertaEl.hidden = false;
    ofertaEl.scrollIntoView({ behavior: "smooth", block: "center" });
    $("#lead-email").focus();
  }

  // ── Envío del lead ────────────────────────────────────────────────────────
  $("#form-lead").addEventListener("submit", async (e) => {
    e.preventDefault();
    const msgEl = $("#lead-msg");
    const email = $("#lead-email").value.trim();
    const rgpd = $("#lead-rgpd").checked;
    const perfil = $("#lead-perfil").value;

    msgEl.className = "form-msg";
    msgEl.textContent = "";

    if (!email || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
      msgEl.classList.add("error");
      msgEl.textContent = "Introduce un email válido.";
      return;
    }
    if (!rgpd) {
      msgEl.classList.add("error");
      msgEl.textContent = "Debes aceptar la política de privacidad.";
      return;
    }

    const btn = $("#lead-submit");
    btn.disabled = true;
    btn.textContent = "Enviando…";

    try {
      await postNetlify("leads", {
        email,
        perfil,
        resultado_valoracion: $("#lead-resultado").value,
        mensaje: $("#lead-mensaje").value || "",
        rgpd: "si",
      });
    } catch {
      /* En local no hay endpoint de Netlify: continuamos igualmente */
    }

    msgEl.classList.add("ok");
    track("Lead", { perfil });

    // Si pidió el informe, generamos el PDF (carga diferida de pdfmake)
    if (perfil === "informe" && ultimoResultado) {
      msgEl.textContent = "Generando tu informe…";
      try {
        const { generarPDF } = await import("../lib/informe-pdf.js");
        await generarPDF(ultimoResultado, ultimosInputs, textosConfig);
        msgEl.textContent = "¡Listo! Tu informe se está descargando.";
      } catch (err) {
        console.error(err);
        msgEl.classList.remove("ok");
        msgEl.classList.add("error");
        msgEl.textContent = "No se pudo generar el PDF. Inténtalo de nuevo.";
      }
    } else {
      msgEl.textContent = "¡Recibido! Te escribiremos muy pronto.";
    }

    btn.disabled = false;
    btn.textContent = "Enviar";

    // Cierre suave: ofrecemos una llamada con un analista (100 % opcional)
    $("#tel-email-copia").value = email;
    const cierreEl = $("#cierre-suave");
    cierreEl.hidden = false;
    cierreEl.scrollIntoView({ behavior: "smooth", block: "center" });
  });

  // ── Cierre suave: llamada con analista (teléfono opcional) ────────────────
  const telInput = $("#lead-telefono");
  const telSubmit = $("#tel-submit");

  /** Valida un teléfono razonable: 9–15 dígitos, admite +, espacios y guiones. */
  const telValido = (v) => {
    const digitos = v.replace(/[\s\-.()]/g, "").replace(/^\+/, "");
    return /^\d{9,15}$/.test(digitos);
  };

  // El botón solo se activa con un teléfono válido: nunca hay mensaje de error.
  telInput.addEventListener("input", () => {
    telSubmit.disabled = !telValido(telInput.value.trim());
  });

  $("#form-telefono").addEventListener("submit", async (e) => {
    e.preventDefault();
    const tel = telInput.value.trim();
    if (!telValido(tel)) return; // el botón ya lo impide; doble seguridad

    telSubmit.disabled = true;
    telSubmit.textContent = "Enviando…";

    try {
      await postNetlify("leads", {
        email: $("#tel-email-copia").value,
        perfil: "telefono-opcional",
        telefono: tel,
        rgpd: "si",
      });
    } catch {
      /* silencioso en local */
    }

    // Confirmación: sustituimos el formulario por el mensaje de éxito
    $("#form-telefono").hidden = true;
    const telMsg = $("#tel-msg");
    telMsg.className = "form-msg ok";
    telMsg.textContent = "";
    const cierreEl = $("#cierre-suave");
    cierreEl.querySelector("h3").textContent = "¡Hecho! Te llamamos en 1–2 días laborables.";
    cierreEl.querySelector(".cierre-suave-texto").innerHTML =
      "Será una llamada corta y sin compromiso. Si te surge algo antes, escríbenos cuando quieras.";
    cierreEl.querySelector(".cierre-suave-bullets").remove();
  });

  // "Ahora no, gracias": se cierra sin culpabilizar y sin insistir
  $("#tel-no-gracias").addEventListener("click", () => {
    $("#cierre-suave").hidden = true;
  });
</script>
